// ─────────────────────────────────────────────────────────────
// Prisma Schema — Healthcare SaaS Platform
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Role {
  PATIENT
  DOCTOR
  DOCTOR_ASSISTANT
  ADMIN
  SUPER_ADMIN // SaaS platform owner
}

enum PaymentMethod {
  CASH
  BKASH
  NAGAD
  ROCKET
  CARD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum AccountStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ServiceType {
  IN_PERSON     // physical visit at clinic
  VIDEO_CALL    // live video consultation
  AUDIO_CALL    // phone / audio only
  CHAT          // async text chat
  HOME_VISIT    // doctor visits patient's home
  REPORT_REVIEW // patient uploads report, doctor reviews async
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum VerificationStatus {
  PENDING
  USED
  EXPIRED
}

enum VerificationCodeType {
  ACCOUNT_ACTIVATION
  PASSWORD_RESET
  EMAIL_CHANGE
  PHONE_CHANGE
  TWO_FACTOR_AUTH
  TWO_FACTOR_AUTH_DISABLE
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum PrescriptionStatus {
  DRAFT
  FINALIZED
  PRINTED
}

enum DrugForm {
  TABLET
  CAPSULE
  SYRUP
  INJECTION
  INHALER
  DROP
  CREAM
  SUPPOSITORY
  PATCH
  OTHER
}

enum TemplateType {
  ADVICE
  DRUG
  TREATMENT
  PRESCRIPTION
  INVESTIGATION
}

enum DurationUnit {
  DAYS
  WEEKS
  MONTHS
  YEARS
}

enum ReferralAgentType {
  MARKETING_OFFICER
  CLINIC_MANAGER
  EXTERNAL_AGENT
  DOCTOR
  OTHER
}

enum CommissionType {
  FLAT        // fixed BDT amount per patient
  PERCENTAGE  // % of consultation fee
  NONE
}

// SaaS subscription tiers
enum PlanTier {
  FREE
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

// SaaS subscription billing status
enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  TRIAL
  PAST_DUE
}

// SaaS invoice / billing cycle
enum BillingCycle {
  MONTHLY
  YEARLY
}

// ─────────────────────────────────────────────────────────────
// USER MODEL
// ─────────────────────────────────────────────────────────────

model User {
  id       String        @id @default(cuid())
  name     String
  email    String        @unique
  phone    String?
  password String
  role     Role          @default(PATIENT)
  verified Boolean       @default(false)
  status   AccountStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Doctor ↔ Assistant self-relation ──────────────────────
  assistantId String?
  doctor      User?   @relation("DoctorAssistant", fields: [assistantId], references: [id])
  assistants  User[]  @relation("DoctorAssistant")

  // ── Auth relations ─────────────────────────────────────────
  verificationCodes VerificationCode[]
  refreshTokens     Refresh[]

  // ── Appointment relations ──────────────────────────────────
  patientAppointments Appointment[] @relation("PatientAppointments")
  doctorAppointments  Appointment[] @relation("DoctorAppointments")
  bookedAppointments  Appointment[] @relation("BookedByUser")

  // ── Profile extensions ─────────────────────────────────────
  patientProfile PatientProfile?
  doctorProfile  DoctorProfile?

  // ── Doctor services (what services the doctor offers) ─────
  doctorServices DoctorService[]

  // ── Template ownership ─────────────────────────────────────
  adviceTemplates       AdviceTemplate[]
  drugTemplates         DrugTemplate[]
  treatmentTemplates    TreatmentTemplate[]
  prescriptionTemplates PrescriptionTemplate[]

  // ---- Prescriptions _______________________________
  doctorPrescriptions  Prescription[] @relation("DoctorPrescriptions")
  patientPrescriptions Prescription[] @relation("PatientPrescriptions")

  // ── Payment relations ──────────────────────────────────────
  payments Payment[]

  // ── SaaS subscription (one per clinic owner / admin) ──────
  subscription Subscription?

  // ── Audit ──────────────────────────────────────────────────
  auditLogs AuditLog[]
}

// ─────────────────────────────────────────────────────────────
// PATIENT PROFILE
// ─────────────────────────────────────────────────────────────

model PatientProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  regNo       String?   @unique
  dateOfBirth DateTime?
  sex         Sex? 
  bloodGroup  String?
  address     String?
  weightKg    Decimal?  @db.Decimal(5, 2)
  heightCm    Decimal?  @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// DOCTOR PROFILE
// ─────────────────────────────────────────────────────────────

model DoctorProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // coverImageUrl    String?
  // profileImageUrl  String?
  specialty         String?
  qualifications    String?
  licenseNo         String? @unique
  signatureImageUrl String?
  clinicName        String?
  clinicAddress     String?
  isAvailable       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// DOCTOR SERVICE
// Per-doctor catalogue of offered services with individual
// pricing and duration. A doctor can offer multiple service
// types (e.g. IN_PERSON + VIDEO_CALL) each with its own fee.
// ─────────────────────────────────────────────────────────────

model DoctorService {
  id           String @id @default(cuid())
  doctorId     String
  doctor       User   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  serviceType  ServiceType
  fee          Decimal     @db.Decimal(10, 2)
  duration     Int         // in minutes e.g. 15 | 30 | 60
  isActive     Boolean     @default(true)
  description  String?     // optional note to patient e.g. "Includes prescription"

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointments Appointment[]

  @@unique([doctorId, serviceType]) // one config per service type per doctor
  @@index([doctorId])
}

// ─────────────────────────────────────────────────────────────
// REFERRAL AGENT
// ─────────────────────────────────────────────────────────────

model ReferralAgent {
  id           String            @id @default(cuid())
  name         String
  phone        String?           @unique
  email        String?           @unique
  organization String?
  agentType    ReferralAgentType @default(OTHER)

  commissionType  CommissionType @default(NONE)
  commissionValue Decimal?       @db.Decimal(8, 2)

  isActive Boolean @default(true)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referrals Referral[]

  @@index([agentType])
}

// ─────────────────────────────────────────────────────────────
// REFERRAL
// ─────────────────────────────────────────────────────────────

model Referral {
  id      String        @id @default(cuid())
  agentId String
  agent   ReferralAgent @relation(fields: [agentId], references: [id])

  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  commissionType   CommissionType @default(NONE)
  commissionValue  Decimal?       @db.Decimal(8, 2)
  commissionEarned Decimal?       @db.Decimal(10, 2)

  isPaid Boolean   @default(false)
  paidAt DateTime?
  notes  String?

  createdAt DateTime @default(now())

  @@index([agentId])
}

// ─────────────────────────────────────────────────────────────
// APPOINTMENT SERIAL
// ─────────────────────────────────────────────────────────────

model AppointmentSerial {
  id         String   @id @default(cuid())
  doctorId   String
  serialDate DateTime @db.Date
  lastSerial Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([doctorId, serialDate])
  @@index([doctorId])
}

// ─────────────────────────────────────────────────────────────
// APPOINTMENT
// ─────────────────────────────────────────────────────────────

model Appointment {
  id String   @id @default(cuid())

  patientId   String
  patient     User   @relation("PatientAppointments", fields: [patientId], references: [id])

  doctorId    String
  doctor      User   @relation("DoctorAppointments", fields: [doctorId], references: [id])

  bookedById  String?
  bookedBy    User?   @relation("BookedByUser", fields: [bookedById], references: [id])

  // Service link — which service the patient booked
  serviceId       String?
  service         DoctorService? @relation(fields: [serviceId], references: [id])
  serviceType     ServiceType    @default(IN_PERSON)

  serialNo        Int?
  fee             Int
  status          AppointmentStatus @default(PENDING)
  paymentMethod   PaymentMethod     @default(CASH)
  paymentStatus   Boolean           @default(false)
  appointmentDate DateTime
  location        String?
  chiefComplaint  String?
  notes           String?

  // ── Video / Audio call fields ──────────────────────────────
  callRoomId       String?   // Daily.co / Jitsi / Whereby room ID
  callStartedAt    DateTime?
  callEndedAt      DateTime?
  callDurationMin  Int?      // actual minutes consumed
  callRecordingUrl String?   // link to recorded session (if enabled)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prescription Prescription?
  payments     Payment[]
  referral     Referral?

  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentDate])
  @@index([doctorId, appointmentDate])
  @@index([serviceType])
}

// ─────────────────────────────────────────────────────────────
// PRESCRIPTION (root clinical record)
// ─────────────────────────────────────────────────────────────

model Prescription {
  id            String     @id @default(cuid())
  appointmentId String     @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  doctorId      String
  doctor        User   @relation("DoctorPrescriptions",  fields: [doctorId],  references: [id])
  patientId     String
  patient       User   @relation("PatientPrescriptions", fields: [patientId], references: [id])

  prescriptionDate DateTime           @default(now())
  status           PrescriptionStatus @default(DRAFT)
  headerTemplate   String?
  clinicalNotes    String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  chiefComplaints ChiefComplaint[]
  history         History?
  examinations    Examination[]
  diagnoses       Diagnosis[]
  investigations  Investigation[]
  rxItems         RxItem[]
  advices         PrescriptionAdvice[]
  reportEntries   ReportEntry[]
  bmiRecord       BmiRecord?
  drugHistories   DrugHistory[]
  plans           Plan[]
  notes           Note[]

  @@index([doctorId])
  @@index([patientId])
}

// ─────────────────────────────────────────────────────────────
// C/C — CHIEF COMPLAINTS
// ─────────────────────────────────────────────────────────────

model ChiefComplaint {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  complaint      String
  duration       String?
  durationUnit   DurationUnit?
  sortOrder      Int           @default(0)
}

// ─────────────────────────────────────────────────────────────
// H/O — HISTORY
// ─────────────────────────────────────────────────────────────

model History {
  id                  String       @id @default(cuid())
  prescriptionId      String       @unique
  prescription        Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  htn                 Boolean @default(false)
  dm                  Boolean @default(false)
  copd                Boolean @default(false)
  ihd                 Boolean @default(false)
  ckd                 Boolean @default(false)
  cld                 Boolean @default(false)
  tobaccoChewing      Boolean @default(false)
  smoking             Boolean @default(false)
  cvd                 Boolean @default(false)
  asthma              Boolean @default(false)
  malignancy          Boolean @default(false)
  allergy             Boolean @default(false)
  psychiatricDisorder Boolean @default(false)
  drugAbuse           Boolean @default(false)
  depression          Boolean @default(false)
  otherNotes          String?
}

// ─────────────────────────────────────────────────────────────
// O/E — EXAMINATIONS
// ─────────────────────────────────────────────────────────────

model Examination {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  parameter   String
  value       String?
  unit        String?
  sortOrder   Int     @default(0)

  @@index([prescriptionId])
}

// ─────────────────────────────────────────────────────────────
// D/X — DIAGNOSES
// ─────────────────────────────────────────────────────────────

model Diagnosis {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  diagnosisText  String
  sortOrder      Int @default(0)
}

// ─────────────────────────────────────────────────────────────
// I/X — INVESTIGATIONS
// ─────────────────────────────────────────────────────────────

model Investigation {
  id                String       @id @default(cuid())
  prescriptionId    String
  prescription      Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  investigationName String
  sortOrder         Int @default(0)
}

// ─────────────────────────────────────────────────────────────
// DRUG DATABASE (master catalogue)
// ─────────────────────────────────────────────────────────────

model DrugDatabase {
  id          String   @id @default(cuid())
  brandName   String
  genericName String?
  drugClass   String?
  strength    String?
  form        DrugForm @default(TABLET)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rxItems                   RxItem[]
  drugTemplateItems         DrugTemplateItem[]
  prescriptionTemplateItems PrescriptionTemplateItem[]

  @@index([brandName])
  @@index([genericName])
}

// ─────────────────────────────────────────────────────────────
// Rx — PRESCRIPTION DRUG ITEMS
// ─────────────────────────────────────────────────────────────

model RxItem {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  drugId      String?
  drug        DrugDatabase? @relation(fields: [drugId], references: [id])

  itemNo      Int
  customBrand String?
  dose        String?
  instruction String?
  duration    String?
  sortOrder   Int       @default(0)

  @@index([prescriptionId])
}

// ─────────────────────────────────────────────────────────────
// ADVICE
// ─────────────────────────────────────────────────────────────

model PrescriptionAdvice {
  id               String       @id @default(cuid())
  prescriptionId   String
  prescription     Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  adviceText       String?
  nextVisitDate    String?
  fee              Decimal? @db.Decimal(10, 2)
  visitNo          Int?
  doctorContact    String?
  emergencyContact String?
  sortOrder        Int @default(0)
}

// ─────────────────────────────────────────────────────────────
// REPORT ENTRY
// ─────────────────────────────────────────────────────────────

model ReportEntry {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  reportDate  DateTime?
  reportName  String
  resultValue String?
  unit        String?
}

// ─────────────────────────────────────────────────────────────
// BMI RECORD
// ─────────────────────────────────────────────────────────────

model BmiRecord {
  id             String       @id @default(cuid())
  prescriptionId String       @unique
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  weightKg      Decimal? @db.Decimal(5, 2)
  heightFeet    Decimal? @db.Decimal(4, 2)
  heightInches  Decimal? @db.Decimal(4, 2)
  bmiValue      Decimal? @db.Decimal(5, 2)
  bmiClass      String?
  idealWeightKg Decimal? @db.Decimal(5, 2)
  insulin       Decimal? @db.Decimal(6, 2)
  qScore        Decimal? @db.Decimal(6, 2)
  wwi           Decimal? @db.Decimal(6, 2)
  bild          Decimal? @db.Decimal(6, 2)
}

// ─────────────────────────────────────────────────────────────
// DRUG HISTORY
// ─────────────────────────────────────────────────────────────

model DrugHistory {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  drugName     String
  details      String?
  sortOrder    Int @default(0)
}

// ─────────────────────────────────────────────────────────────
// PLAN
// ─────────────────────────────────────────────────────────────

model Plan {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  planText       String
  sortOrder      Int @default(0)
}

// ─────────────────────────────────────────────────────────────
// NOTE
// ─────────────────────────────────────────────────────────────

model Note {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  noteText  String
  sortOrder Int @default(0)
}

// ─────────────────────────────────────────────────────────────
// TEMPLATES
// ─────────────────────────────────────────────────────────────

model AdviceTemplate {
  id       String @id @default(cuid())
  doctorId String
  doctor   User   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  templateName String
  adviceText   String
  isShared     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId])
}

model DrugTemplate {
  id       String @id @default(cuid())
  doctorId String
  doctor   User   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  templateName String
  isShared     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items DrugTemplateItem[]

  @@index([doctorId])
}

model DrugTemplateItem {
  id         String       @id @default(cuid())
  templateId String
  template   DrugTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  drugId      String?
  drug        DrugDatabase? @relation(fields: [drugId], references: [id])

  customBrand String?
  dose        String?
  instruction String?
  duration    String?
  sortOrder   Int @default(0)
}

model TreatmentTemplate {
  id       String @id @default(cuid())
  doctorId String
  doctor   User   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  templateName   String
  treatmentNotes String
  isShared       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId])
}

model PrescriptionTemplate {
  id       String @id @default(cuid())
  doctorId String
  doctor   User   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  templateName String
  isShared     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PrescriptionTemplateItem[]

  @@index([doctorId])
}

model PrescriptionTemplateItem {
  id         String               @id @default(cuid())
  templateId String
  template   PrescriptionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  drugId        String?
  drug          DrugDatabase? @relation(fields: [drugId], references: [id])

  diagnosisText String?
  adviceText    String?
  customBrand   String?
  dose          String?
  instruction   String?
  duration      String?
  sortOrder     Int @default(0)
}

// ─────────────────────────────────────────────────────────────
// PAYMENT  (per-appointment)
// ─────────────────────────────────────────────────────────────

model Payment {
  id String @id @default(cuid())

  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  patientId String
  patient   User   @relation(fields: [patientId], references: [id])

  amount  Decimal       @db.Decimal(10, 2)
  method  PaymentMethod @default(CASH)
  status  PaymentStatus @default(PENDING)

  phoneNumber   String?
  transactionId String?  @unique

  receiptNo    String?  @unique
  paymentProof String?
  note         String?

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([appointmentId])
  @@index([patientId])
}

// ─────────────────────────────────────────────────────────────
// ══════════════════════════════════════════════════════════════
//  SaaS BILLING LAYER
//  SaasPlan → Subscription → Invoice
// ══════════════════════════════════════════════════════════════
// ─────────────────────────────────────────────────────────────

// ── SaaS Plan (defined by platform owner) ────────────────────

model SaasPlan {
  id   String   @id @default(cuid())
  name String   @unique // "Free" | "Basic" | "Professional" | "Enterprise"
  tier PlanTier

  monthlyPrice Decimal @db.Decimal(10, 2) // BDT per month
  yearlyPrice  Decimal @db.Decimal(10, 2) // BDT per year (usually discounted)

  // Limits
  maxDoctors      Int @default(1)   // doctors allowed under this plan
  maxPatients     Int @default(500) // active patients
  maxStorageGb    Int @default(1)   // file/image storage GB
  maxAppointments Int @default(200) // appointments per month; -1 = unlimited

  // Feature flags stored as JSON for flexibility
  // e.g. { "videoCall": true, "audioCall": true, "homeVisit": false,
  //        "reportReview": true, "customBranding": false, "apiAccess": false }
  features Json

  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
}

// ── Subscription (one per clinic / admin user) ────────────────

model Subscription {
  id     String @id @default(cuid())
  userId String @unique  // clinic owner / ADMIN
  user   User   @relation(fields: [userId], references: [id])

  planId String
  plan   SaasPlan @relation(fields: [planId], references: [id])

  status       SubscriptionStatus @default(TRIAL)
  billingCycle BillingCycle       @default(MONTHLY)

  trialEndsAt   DateTime?
  startDate     DateTime
  endDate       DateTime  // next renewal / expiry date
  autoRenew     Boolean   @default(true)

  lastPaidAt    DateTime?
  nextBillingAt DateTime?

  // Soft cancellation
  cancelledAt     DateTime?
  cancellationNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]

  @@index([userId])
  @@index([status])
}

// ── Invoice (one per billing cycle payment) ───────────────────

model Invoice {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  amount       Decimal       @db.Decimal(10, 2)
  currency     String        @default("BDT")
  status       PaymentStatus @default(PENDING)
  billingCycle BillingCycle  @default(MONTHLY)

  // Period this invoice covers
  periodStart DateTime
  periodEnd   DateTime

  // Payment details
  method        PaymentMethod? // BKASH | CARD etc.
  transactionId String?        @unique
  receiptNo     String?        @unique

  issuedAt  DateTime  @default(now())
  paidAt    DateTime?
  dueDate   DateTime?

  @@index([subscriptionId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  action    String  // CREATE | UPDATE | DELETE | LOGIN | PRINT
  tableName String
  recordId  String?
  changes   Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tableName, recordId])
}

// ─────────────────────────────────────────────────────────────
// VERIFICATION CODE
// ─────────────────────────────────────────────────────────────

model VerificationCode {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status     VerificationStatus   @default(PENDING)
  code       String
  type       VerificationCodeType @default(ACCOUNT_ACTIVATION)
  issuedAt   DateTime             @default(now())
  expiresAt  DateTime
  verifiedAt DateTime?
}

// ─────────────────────────────────────────────────────────────
// REFRESH TOKEN
// ─────────────────────────────────────────────────────────────

model Refresh {
  id        String   @id @default(cuid())
  userId    String
  email     String
  token     String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
